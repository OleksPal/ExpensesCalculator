# Environment Variables Example
# Copy this file to .env and replace placeholders with your actual values
# IMPORTANT: Never commit the .env file to version control!

# SQL Server Configuration
# IMPORTANT: Use a strong password (min 8 chars, uppercase, lowercase, numbers, special chars)
SA_PASSWORD=your-strong-password-here

# JWT Configuration
# IMPORTANT: Generate a random secret key (min 32 characters)
# You can generate one using: openssl rand -base64 32
# Or online at: https://generate-random.org/api-key-generator
JWT_SECRET_KEY=your-generated-jwt-secret-key-min-32-chars

# Application Configuration
ASPNETCORE_ENVIRONMENT=Production

# CORS Configuration (adjust based on your frontend URL)
Cors__AllowedOrigins__0=http://localhost:8080

# Azure Production Configuration (when deploying to Azure)
# Replace with your actual Azure SQL Database connection string
# ConnectionStrings__DefaultConnection=Server=tcp:your-server.database.windows.net,1433;Database=Expenses;User ID=your-admin;Password=your-password;Encrypt=True;TrustServerCertificate=False;
# Cors__AllowedOrigins__0=https://your-app.azurewebsites.net
